# =============================================================================
# ComfyUI + Docker - Configuración de entorno
# =============================================================================
# Copia este archivo a .env y ajusta los valores según tu entorno:
#   cp .env.example .env
# =============================================================================

# Puerto donde se expone ComfyUI (host:contenedor)
# Por defecto: 8188
COMFYUI_PORT=8188

# Argumentos de inicio de ComfyUI
# Opciones comunes:
#   --listen 0.0.0.0    Expone en todas las interfaces (requerido para Docker)
#   --port 8188         Puerto interno del contenedor
#   --normalvram        VRAM mode: auto (default), normalvram, lowvram, highvram
#   --force-fp16        Usa precisión fp16 (ahorra VRAM)
#   --cpu               Forzar CPU (sin GPU)
#   --highvram          Cargar todo el modelo en VRAM (más rápido, más VRAM)
#   --lowvram           Mínimo uso de VRAM (lento, para GPUs con <6GB)
# Ejemplo RTX 5050 8GB: --listen 0.0.0.0 --port 8188 --normalvram --force-fp16
# Ejemplo CPU:         --listen 0.0.0.0 --port 8188 --cpu
COMFYUI_ARGS=--listen 0.0.0.0 --port 8188 --normalvram --force-fp16

# Nombre del checkpoint SDXL
# Se busca en models/checkpoints/ y se descarga automáticamente si no existe
SDXL_MODEL=juggernautXL_v8Rundiffusion.safetensors

# Nombre del checkpoint FLUX (descarga manual con download_models.py)
FLUX_MODEL=flux1-dev-bnb-nf4-v2.safetensors

# Puerto del frontend web
FRONTEND_PORT=8080